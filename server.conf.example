# Web Server Configuration Template
# This is a sample configuration for the web application server

# Server Settings
server_name = "web-app-server"
listen_port = 443
ssl_enabled = true
auto_ssl = true

# Domain Configuration  
primary_domain = "example.com"
api_endpoint = "/api/v1"
health_check = "/health"

# Authentication
auth_method = "basic"
admin_user = "administrator" 
admin_pass = "change-me-please"

# SSL Provider
ssl_provider = "cloudflare"
api_token = "your-cloudflare-token-here"

# Upstream Services
backend_service = "internal-backend:8080"
database_host = "db.internal"
cache_server = "redis.internal:6379"

# Performance Settings
worker_processes = "auto"
max_connections = 1024
keepalive_timeout = 65
gzip_enabled = true

# Logging
log_level = "info"
access_log = "/var/log/access.log"
error_log = "/var/log/error.log"
log_rotation = "daily"

# Security
rate_limiting = true
ddos_protection = true
cors_enabled = false
csrf_protection = true

# Monitoring  
metrics_enabled = true
prometheus_endpoint = "/metrics"
health_endpoint = "/health"