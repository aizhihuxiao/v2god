{
    # 全局性能优化设置
    admin 0.0.0.0:2019
    
    # 日志优化 - 减少I/O开销，但不暴露代理特征
    log {
        output file /var/log/caddy/access.log {
            roll_size 100MiB
            roll_keep 5
            roll_keep_for 168h
        }
        level WARN  # 只记录警告，避免代理流量日志
        format json
    }
    
    # 全局服务器优化
    servers {
        protocol {
            # 启用 HTTP/2，但不启用 HTTP/3（避免检测）
            allow_h2c
        }
        
        # 连接优化 - 模拟正常网站
        max_header_size 16KB
        read_timeout 60s   # 增加超时，模拟正常网站
        write_timeout 60s
        idle_timeout 300s  # 延长空闲时间
        
        # 性能优化
        enable_full_duplex
    }
    
    # TLS 性能优化
    default_bind 0.0.0.0
}

:443, *.domain, domain {
    # TLS 优化配置 - 模拟主流网站
    tls {
        dns cloudflare cloudflareApiToken
        
        # 使用主流的密码套件，不要太激进
        ciphers TLS_AES_256_GCM_SHA384 TLS_CHACHA20_POLY1305_SHA256 TLS_AES_128_GCM_SHA256
        curves X25519 P-256
        
        # 启用 OCSP Stapling
        ocsp_stapling on
    }
    
    # 伪装优先的路由配置
    route {
        # NaiveProxy 路径 - 隐蔽性优先
        reverse_proxy /proxyPath localhost:2333 {
            # 保持必要的头部，模拟正常代理
            header_up Host {upstream_hostport}
            header_up X-Forwarded-For {remote_host}
            header_up X-Real-IP {remote_host}
            
            # 温和的连接池优化，不要过于激进
            transport http {
                keepalive 60s
                keepalive_idle_conns 50  # 适中的连接数
                
                # 超时设置模拟正常网站
                dial_timeout 10s
                response_header_timeout 30s
                
                # 适中的缓冲区
                read_buffer_size 4096
                write_buffer_size 4096
            }
            
            # 健康检查不要太频繁
            health_interval 60s
            health_timeout 10s
        }
        
        # Forward Proxy 配置 - 必须保持完整的伪装
        forward_proxy {
            basic_auth naiveUser naivePasswd
            hide_ip
            hide_via
            probe_resistance  # 关键：抗探测
            
            # 伪装流量时序
            upstream_timeout 60s
            dial_timeout 30s
        }
        
        # 关键：反向代理到微软更新服务器进行流量伪装
        reverse_proxy https://www.catalog.update.microsoft.com {
            header_up Host {upstream_hostport}
            header_up X-Forward-Host {host}
            header_up User-Agent "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
            header_up Accept "text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8"
            header_up Accept-Language "en-US,en;q=0.5"
            header_up Accept-Encoding "gzip, deflate, br"
            header_up Connection "keep-alive"
            header_up Upgrade-Insecure-Requests "1"
            
            # 模拟正常浏览器行为的连接池
            transport http {
                keepalive 120s
                keepalive_idle_conns 10
                
                dial_timeout 15s
                response_header_timeout 30s
                
                # 模拟正常浏览器的缓冲区大小
                read_buffer_size 4096
                write_buffer_size 4096
            }
        }
    }
    
    # 安全和伪装头部 - 模拟 IIS 服务器
    header {
        # 伪装成 IIS 服务器
        Server "Microsoft-IIS/10.0"
        X-Powered-By "ASP.NET"
        
        # 正常网站的头部
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        
        # 连接优化但不暴露特征
        Connection "keep-alive"
        Keep-Alive "timeout=120"
    }
    
    # 适度压缩，不要过度优化
    encode {
        gzip 4  # 降低压缩级别，模拟普通网站
        minimum_length 1024
    }
    
    # 添加错误页面伪装
    handle_errors {
        @404 expression {http.error.status_code} == 404
        handle @404 {
            respond "<!DOCTYPE html><html><head><title>页面未找到</title></head><body><h1>404 - 页面未找到</h1><p>您访问的页面不存在。</p></body></html>" 404 {
                header Content-Type "text/html; charset=utf-8"
            }
        }
        
        @500 expression {http.error.status_code} == 500
        handle @500 {
            respond "<!DOCTYPE html><html><head><title>服务器错误</title></head><body><h1>500 - 内部服务器错误</h1><p>服务器遇到了一个错误。</p></body></html>" 500 {
                header Content-Type "text/html; charset=utf-8"
            }
        }
    }
}