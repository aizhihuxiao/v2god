{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "inbounds": [
    {
      "type": "vless",
      "tag": "vless-in",
      "listen": "::",
      "listen_port": 443,
      "users": [
        {
          "uuid": "REALITY_UUID",
          "flow": "xtls-rprx-vision"
        }
      ],
      "tls": {
        "enabled": true,
        "server_name": "REALITY_SERVER_NAME",
        "reality": {
          "enabled": true,
          "handshake": {
            "server": "REALITY_SERVER_NAME",
            "server_port": 443
          },
          "private_key": "REALITY_PRIVATE_KEY",
          "short_id": [
            "REALITY_SHORT_ID"
          ]
        }
      }
    },
    {
      "type": "naive",
      "tag": "naive-in",
      "listen": "::",
      "listen_port": 8443,
      "users": [
        {
          "username": "NAIVE_USER",
          "password": "NAIVE_PASSWD"
        }
      ],
      "tls": {
        "enabled": true,
        "server_name": "DOMAIN",
        "acme": {
          "domain": [
            "DOMAIN"
          ],
          "email": "admin@DOMAIN",
          "provider": "cloudflare",
          "dns_challenge": {
            "provider": "cloudflare",
            "api_token": "CLOUDFLARE_API_TOKEN"
          }
        }
      }
    },
    {
      "type": "direct",
      "tag": "redirect-https",
      "listen": "::",
      "listen_port": 80,
      "override_address": "https://DOMAIN",
      "override_port": 443
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "block",
      "tag": "block"
    }
  ],
  "route": {
    "rules": [
      {
        "protocol": "dns",
        "outbound": "direct"
      }
    ],
    "final": "direct"
  }
}
