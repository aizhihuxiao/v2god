{
	admin localhost:2019

	log {
		output file /var/log/caddy/access.log {
			roll_size 10MB
			roll_keep 3
		}
		level INFO
		format json
	}
}

:443, *.yourdomain.com, yourdomain.com {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	}

	route {
		# Internal proxy path
		reverse_proxy /api/* localhost:2333 {
			header_up -Origin
		}

		# Forward proxy configuration
		forward_proxy {
			basic_auth {env.WEB_USER} {env.WEB_PASSWORD}
			hide_ip
			hide_via
			probe_resistance
		}

		# Fallback camouflage
		reverse_proxy https://www.catalog.update.microsoft.com {
			header_up Host {upstream_hostport}
			header_up X-Forward-Host {host}
		}
	}
}