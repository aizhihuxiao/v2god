{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "inbounds": [
    {
      "type": "vless",
      "tag": "vless-in",
      "listen": "::",
      "listen_port": 8443,
      "users": [
        {
          "uuid": "REALITY_UUID",
          "flow": ""
        }
      ],
      "tls": {
        "enabled": true,
        "server_name": "REALITY_SNI",
        "certificate_path": "/data/caddy/certificates/acme.zerossl.com-v2-dv90/wildcard_.domain/wildcard_.domain.crt",
        "key_path": "/data/caddy/certificates/acme.zerossl.com-v2-dv90/wildcard_.domain/wildcard_.domain.key",
        "min_version": "1.2",
        "max_version": "1.3"
      }
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "final": "direct"
  }
}
